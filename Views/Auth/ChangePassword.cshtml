@model BPCVN.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card-lovable card-body-lovable mt-3">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock" style="font-size:2.5rem;color:var(--color-charcoal)"></i>
                <h3 class="text-subheading mt-2">Đổi mật khẩu</h3>
                <p class="text-caption">Nhập mật khẩu hiện tại để xác minh danh tính</p>
            </div>
            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-lovable"></div>

                <!-- Mật khẩu hiện tại -->
                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label-lovable"></label>
                    <input asp-for="CurrentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <hr class="divider">

                <!-- Mật khẩu mới -->
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label-lovable"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Ít nhất 6 ký tự" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <!-- Xác nhận mật khẩu mới -->
                <div class="mb-4">
                    <label asp-for="ConfirmNewPassword" class="form-label-lovable"></label>
                    <input asp-for="ConfirmNewPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn-dark-lovable btn-block py-2 flex-grow-1">
                        <i class="bi bi-check-lg"></i>Đổi mật khẩu
                    </button>
                    <a asp-controller="User" asp-action="Profile" class="btn-ghost py-2">
                        <i class="bi bi-x-lg"></i>Huỷ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
