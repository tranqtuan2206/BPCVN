@model BPCVN.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 p-4 mt-3">

            <div class="text-center mb-4">
                <i class="bi bi-keyboard fs-1" style="color:#6c5ce7"></i>
                <h3 class="fw-bold mt-2">Đăng nhập</h3>
                <p class="text-muted small">Chào mừng trở lại BPCVN</p>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger small rounded-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-500"></label>
                    <input asp-for="Email" class="form-control rounded-3"
                           placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-500"></label>
                    <input asp-for="Password" class="form-control rounded-3"
                           placeholder="Mật khẩu của bạn" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted small"></label>
                </div>

                <button type="submit" class="btn w-100 fw-600 py-2 rounded-3"
                        style="background:#6c5ce7;color:#fff;font-weight:600">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                </button>
            </form>

            <hr class="my-4">
            <p class="text-center text-muted small mb-0">
                Chưa có tài khoản?
                <a asp-controller="Auth" asp-action="Register"
                   style="color:#6c5ce7;font-weight:600">Đăng ký ngay</a>
            </p>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}