@model BPCVN.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 p-4 mt-3">

            <div class="text-center mb-4">
                <i class="bi bi-person-plus-fill fs-1" style="color:#6c5ce7"></i>
                <h3 class="fw-bold mt-2">Tạo tài khoản</h3>
                <p class="text-muted small">Tham gia cộng đồng BPCVN ngay hôm nay</p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger small rounded-3" style="display:none"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-500"></label>
                    <input asp-for="Username" class="form-control rounded-3"
                           placeholder="Nhập username..." />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-500"></label>
                    <input asp-for="Email" class="form-control rounded-3"
                           placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-500"></label>
                    <input asp-for="Password" class="form-control rounded-3"
                           placeholder="Tối thiểu 6 ký tự" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-500"></label>
                    <input asp-for="ConfirmPassword" class="form-control rounded-3"
                           placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn w-100 fw-600 py-2 rounded-3"
                        style="background:#6c5ce7;color:#fff;font-weight:600">
                    <i class="bi bi-person-check me-2"></i>Đăng ký
                </button>
            </form>

            <hr class="my-4">
            <p class="text-center text-muted small mb-0">
                Đã có tài khoản?
                <a asp-controller="Auth" asp-action="Login"
                   style="color:#6c5ce7;font-weight:600">Đăng nhập</a>
            </p>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}