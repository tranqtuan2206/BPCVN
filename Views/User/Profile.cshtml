@model BPCVN.Models.Entities.User
@{
    ViewData["Title"] = "Trang cá nhân";
    int totalSoundTests = Model.Specs.Sum(s => s.SoundTests.Count);
    int totalUpvotes    = Model.Specs
                               .SelectMany(s => s.SoundTests)
                               .Sum(st => st.Upvotes);
}

<!-- Header profile -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4"
     style="background:linear-gradient(135deg,#ede9fe,#f5f4fb)">
    <div class="d-flex align-items-center gap-4 flex-wrap">
        <!-- Avatar -->
        <div class="rounded-circle d-flex align-items-center justify-content-center
                    fw-bold text-white flex-shrink-0"
             style="width:72px;height:72px;background:#6c5ce7;font-size:1.8rem">
            @Model.Username[0].ToString().ToUpper()
        </div>
        <div class="flex-grow-1">
            <h3 class="fw-bold mb-1" style="color:#1a1a2e">@Model.Username</h3>
            <p class="text-muted small mb-2">
                <i class="bi bi-envelope me-1"></i>@Model.Email
                &nbsp;·&nbsp;
                <i class="bi bi-calendar3 me-1"></i>
                Tham gia @Model.CreatedAt.ToString("MM/yyyy")
            </p>
            <!-- Stats nhanh -->
            <div class="d-flex gap-3 flex-wrap">
                <span class="badge rounded-pill px-3 py-2"
                      style="background:#fff;color:#5849c2;font-size:.85rem">
                    <i class="bi bi-collection me-1"></i>@Model.Specs.Count Builds
                </span>
                <span class="badge rounded-pill px-3 py-2"
                      style="background:#fff;color:#00816a;font-size:.85rem">
                    <i class="bi bi-soundwave me-1"></i>@totalSoundTests Sound Tests
                </span>
                <span class="badge rounded-pill px-3 py-2"
                      style="background:#fff;color:#c0397a;font-size:.85rem">
                    <i class="bi bi-heart me-1"></i>@totalUpvotes Upvotes nhận được
                </span>
            </div>
        </div>
        <a asp-controller="Spec" asp-action="Create"
           class="btn rounded-3 align-self-start"
           style="background:#6c5ce7;color:#fff;font-weight:600">
            <i class="bi bi-plus-circle me-1"></i>Build mới
        </a>
    </div>
</div>

<!-- Danh sách builds -->
<h5 class="fw-bold mb-3" style="color:#1a1a2e">
    <i class="bi bi-collection me-2" style="color:#6c5ce7"></i>Builds của tôi
</h5>

@if (!Model.Specs.Any())
{
    <div class="text-center py-5 text-muted card border-0 shadow-sm rounded-4">
        <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
        <p class="mb-3">Bạn chưa có build nào.</p>
        <a asp-controller="Spec" asp-action="Create"
           class="btn rounded-3 px-4 mx-auto"
           style="background:#6c5ce7;color:#fff;font-weight:600;width:fit-content">
            Tạo build đầu tiên
        </a>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var spec in Model.Specs.OrderByDescending(s => s.CreatedAt))
        {
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex align-items-start
                            justify-content-between gap-3 flex-wrap">

                    <!-- Thông tin build -->
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                            <h5 class="fw-bold mb-0" style="color:#1a1a2e">
                                @spec.BuildName
                            </h5>
                            <span class="badge rounded-pill"
                                  style="background:#ede9fe;color:#5849c2;font-size:.75rem">
                                @spec.Kit.Layout
                            </span>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="small text-muted">
                                <i class="bi bi-cpu me-1" style="color:#6c5ce7"></i>
                                @spec.Kit.Name
                            </span>
                            <span class="text-muted">·</span>
                            <span class="small text-muted">
                                <i class="bi bi-toggles me-1" style="color:#00b894"></i>
                                @spec.Switch.Name
                            </span>
                            <span class="text-muted">·</span>
                            <span class="small text-muted">
                                <i class="bi bi-soundwave me-1" style="color:#fd79a8"></i>
                                @spec.SoundTests.Count sound test(s)
                            </span>
                        </div>

                        <!-- Audio player nếu có -->
                        @if (spec.SoundTests.Any())
                        {
                            var best = spec.SoundTests.OrderByDescending(st => st.Upvotes).First();
                            <audio controls class="w-100" style="height:36px;max-width:400px">
                                <source src="@best.AudioUrl" />
                            </audio>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="d-flex flex-column gap-2 flex-shrink-0">
                        <a asp-controller="Spec" asp-action="Details"
                           asp-route-id="@spec.SpecId"
                           class="btn btn-sm rounded-3"
                           style="background:#ede9fe;color:#5849c2;font-weight:600">
                            <i class="bi bi-eye me-1"></i>Xem
                        </a>
                        <a asp-controller="SoundTest" asp-action="Upload"
                           asp-route-specId="@spec.SpecId"
                           class="btn btn-sm rounded-3"
                           style="background:#e8f8f1;color:#00816a;font-weight:600">
                            <i class="bi bi-cloud-upload me-1"></i>Upload
                        </a>

                        <!-- Nút Xóa với confirm -->
                        <form asp-controller="User" asp-action="DeleteSpec"
                              method="post"
                              onsubmit="return confirm('Xóa build \'@spec.BuildName\'?\nHành động này không thể hoàn tác.')">
                            <input type="hidden" name="specId" value="@spec.SpecId" />
                            <button type="submit"
                                    class="btn btn-sm rounded-3 w-100"
                                    style="background:#fde8f1;color:#c0397a;font-weight:600">
                                <i class="bi bi-trash me-1"></i>Xóa
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        }
    </div>
}