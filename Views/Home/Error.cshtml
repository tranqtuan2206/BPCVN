@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card bg-dark text-white" style="border: 1px solid rgba(255, 105, 180, 0.2); box-shadow: 0 8px 32px rgba(255, 105, 180, 0.1);">
                <div class="card-body py-5">
                    <h1 class="display-1 text-danger text-pixel" style="font-size: 3rem;" data-i18n="home.error.title">Opps!</h1>
                    <h2 class="mt-4 mb-3 text-pixel" style=" font-size: 1.5rem;" data-i18n="home.error.subtitle">Cáp quang lại đứt rồi...</h2>
                    <p class="lead mb-4 text-muted" style="font-family: 'VT323', monospace; font-size: 1.5rem;">
                        Hệ thống đang gặp sự cố nhỏ. Quý nhựa thủ vui lòng quay lại sau nhé!
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light px-4 py-2" style="text-decoration: none; font-size: 0.8rem;">
                        <i class="bi bi-house-door me-2"></i>Về Trang Chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>