@model BPCVN.Models.Entities.Spec
@using System.Security.Claims
@{
    ViewData["Title"] = Model.BuildName;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = currentUserId == Model.UserId.ToString();
    var isAdmin = User.IsInRole("Admin");
}

<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h2 class="section-title mb-1">@Model.BuildName</h2>
        <p class="text-caption mb-0">
            <i class="bi bi-person-circle me-1"></i>@Model.User.Username &nbsp;·&nbsp;
            <i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("dd/MM/yyyy")
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (isOwner)
        {
            <!-- Upload Sound Test — chỉ owner -->
            <a asp-controller="SoundTest" asp-action="Upload" asp-route-specId="@Model.SpecId" class="btn-dark-lovable">
                <i class="bi bi-cloud-upload"></i><span data-i18n="details.uploadBtn">Upload Sound Test</span>
            </a>
            <!-- Sửa Build — chỉ owner -->
            <a asp-controller="Spec" asp-action="Edit" asp-route-id="@Model.SpecId" class="btn-ghost">
                <i class="bi bi-pencil-square"></i>Sửa
            </a>
        }
        @if (isOwner || isAdmin)
        {
            <!-- Xóa Build — owner hoặc Admin -->
            <form asp-controller="Spec" asp-action="Delete" asp-route-id="@Model.SpecId" method="post"
                  onsubmit="return confirm('Xóa build \'@Model.BuildName\'?\nHành động này không thể hoàn tác.')">
                <button type="submit" class="btn-ghost btn-sm-lovable"
                        style="color:#b91c1c;border-color:rgba(185,28,28,0.3)">
                    <i class="bi bi-trash"></i>Xóa
                </button>
            </form>
        }
    </div>
</div>

<!-- Thông số build -->
<div class="card-lovable card-body-lovable mb-4">
    <h5 style="font-weight:600;color:var(--color-charcoal);margin-bottom:16px">
        <i class="bi bi-sliders me-2" style="opacity:0.5"></i><span data-i18n="details.specTitle">Thông số cấu hình</span>
    </h5>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-cpu me-1"></i>Kit</div>
                <div style="font-weight:600;color:var(--color-charcoal)">@Model.Kit.Name</div>
                <div class="text-caption">@Model.Kit.Brand · @Model.Kit.Layout</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-toggles me-1"></i>Switch</div>
                <div style="font-weight:600;color:var(--color-charcoal)">@Model.Switch.Name</div>
                <div class="text-caption">@Model.Switch.Brand · @Model.Switch.Type</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-grid me-1"></i>Keycap</div>
                @if (Model.Keycap != null)
                {
                    <div style="font-weight:600;color:var(--color-charcoal)">@Model.Keycap.Name</div>
                    <div class="text-caption">@Model.Keycap.Brand · @Model.Keycap.Profile</div>
                }
                else
                {
                    <div class="text-caption" style="font-style:italic" data-i18n="details.none">Không có</div>
                }
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.PlateMaterial))
        {
            <div class="col-md-4">
                <div class="info-block">
                    <div class="text-caption mb-1"><i class="bi bi-layers me-1"></i>Plate</div>
                    <div style="font-weight:600;color:var(--color-charcoal)">@Model.PlateMaterial</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.FoamSetup))
        {
            <div class="col-md-4">
                <div class="info-block">
                    <div class="text-caption mb-1"><i class="bi bi-stack me-1"></i>Foam Setup</div>
                    <div style="font-weight:600;color:var(--color-charcoal)">@Model.FoamSetup</div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.Mods))
        {
            <div class="col-12">
                <div class="info-block">
                    <div class="text-caption mb-1"><i class="bi bi-tools me-1"></i>Mods</div>
                    <div style="font-weight:600;color:var(--color-charcoal)">@Model.Mods</div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Sound Tests -->
<div class="card-lovable card-body-lovable">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 style="font-weight:600;color:var(--color-charcoal);margin:0">
            <i class="bi bi-soundwave me-2" style="opacity:0.5"></i>Sound Tests
            <span class="badge-count ms-2">@Model.SoundTests.Count</span>
        </h5>
    </div>
    @if (!Model.SoundTests.Any())
    {
        <div class="empty-state" style="padding:32px 16px">
            <i class="bi bi-mic-mute empty-icon" style="font-size:2.5rem"></i>
            <p class="mb-0" data-i18n="details.noSoundTest">Chưa có sound test nào.</p>
            @if (isOwner)
            {
                <a asp-controller="SoundTest" asp-action="Upload" asp-route-specId="@Model.SpecId"
                    class="btn-dark-lovable btn-sm-lovable mt-3" data-i18n="details.uploadNow">Upload ngay</a>
            }
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var st in Model.SoundTests)
            {
                <div class="audio-container" style="padding:16px">
                    <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
                        <div>
                            <span style="font-weight:600;color:var(--color-charcoal)">
                                <i class="bi bi-mic me-1"></i>
                                @(st.MicUsed ?? "Không rõ mic")
                            </span>
                            <span class="text-caption ms-2">@st.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge-count">
                                <i class="bi bi-hand-thumbs-up me-1"></i>@st.Upvotes
                            </span>
                            @if (isOwner || isAdmin)
                            {
                                <!-- Nút xóa Sound Test — owner hoặc Admin -->
                                <form asp-controller="SoundTest" asp-action="Delete" method="post"
                                      onsubmit="return confirm('Xóa sound test này?')">
                                    <input type="hidden" name="testId" value="@st.TestId" />
                                    <button type="submit" class="btn-ghost btn-sm-lovable"
                                            style="color:#b91c1c;border-color:rgba(185,28,28,0.3);padding:4px 8px"
                                            title="Xóa sound test">
                                        <i class="bi bi-trash" style="font-size:0.8rem"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                    <div class="waveform-player">
                        <button type="button" class="waveform-play-btn" title="Play" disabled>
                            <i class="bi bi-hourglass-split waveform-icon-loading"></i>
                        </button>
                        <div class="waveform" data-audio-url="@st.AudioUrl"></div>
                        <div class="waveform-time">
                            <span class="waveform-current-time">0:00</span>
                            <span class="waveform-time-separator">/</span>
                            <span class="waveform-duration">0:00</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>