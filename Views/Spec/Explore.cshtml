@model IEnumerable<BPCVN.Models.Entities.Spec>
@{
    ViewData["Title"] = "Khám phá Builds";
}

<div class="section-header mb-4">
    <div>
        <h2 class="section-title">
            <i class="bi bi-compass me-2" style="opacity:0.5"></i><span data-i18n="explore.title">Khám phá Builds</span>
        </h2>
        <p class="section-subtitle">
            <span data-i18n="explore.found">Tìm thấy</span> <strong id="explore-count">@ViewBag.TotalResults</strong> <span data-i18n="explore.results">kết quả</span>
        </p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Spec" asp-action="Create" class="btn-dark-lovable">
            <i class="bi bi-plus-circle"></i><span data-i18n="nav.createBuild">Tạo Build</span>
        </a>
    }
</div>

<!-- Search & Filter -->
<div class="card-lovable card-body-lovable mb-4">
    <form id="explore-form" method="get" class="row g-3 align-items-end">
        <div class="col-12 col-md-6">
            <label class="form-label-lovable">
                <i class="bi bi-search me-1"></i><span data-i18n="explore.searchLabel">Tìm kiếm</span>
            </label>
            <input type="text" name="searchString" id="explore-search" value="@ViewBag.SearchString"
                class="form-control" autocomplete="off"
                data-i18n-placeholder="explore.searchPlaceholder" placeholder="Nhập tên build, kit, switch..." />
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label-lovable">
                <i class="bi bi-toggles me-1"></i><span data-i18n="explore.switchType">Loại Switch</span>
            </label>
            <select name="switchType" id="explore-switch-type" class="form-select">
                <option value="" data-i18n="explore.allTypes">-- Tất cả loại --</option>
                @foreach (var t in new[] { "Linear", "Tactile", "Clicky" })
                {
                    if ((string?)ViewBag.SwitchType == t)
                    {
                        <option value="@t" selected>@t</option>
                    }
                    else
                    {
                        <option value="@t">@t</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-md-2 d-flex gap-2">
            <button type="submit" class="btn-dark-lovable flex-grow-1">
                <i class="bi bi-funnel"></i><span data-i18n="explore.filter">Lọc</span>
            </button>
        </div>
    </form>
</div>

<!-- Wrapper chứa kết quả — AJAX sẽ inject HTML vào đây -->
<div id="explore-results">
    @await Html.PartialAsync("_ExploreResults", Model)
</div>

@section Scripts {
    <script>
        /* ──────────────────────────────────────────────────────────────────
         *  BPCVN Live Search — gõ đến đâu, kết quả nhảy ra đến đấy
         *  Debounce 300ms — tránh spam request mỗi phím nhấn
         * ────────────────────────────────────────────────────────────────── */

        (function () {
            /* Lấy elements */
            var searchInput    = document.getElementById('explore-search');
            var switchSelect   = document.getElementById('explore-switch-type');
            var resultsWrapper = document.getElementById('explore-results');
            var resultCount    = document.getElementById('explore-count');
            var exploreForm    = document.getElementById('explore-form');
            var timer          = null;

            if (!searchInput || !resultsWrapper) return;

            /* Tạo query string từ giá trị hiện tại */
            function buildQuery() {
                var s = searchInput.value.trim();
                var t = switchSelect ? switchSelect.value : '';
                var p = [];
                if (s) p.push('searchString=' + encodeURIComponent(s));
                if (t) p.push('switchType=' + encodeURIComponent(t));
                return p.length ? '?' + p.join('&') : '';
            }

            /* Fetch kết quả và cập nhật DOM */
            function doSearch() {
                var qs = buildQuery();

                /* Loading state */
                resultsWrapper.style.opacity = '0.4';
                resultsWrapper.style.pointerEvents = 'none';
                resultsWrapper.style.transition = 'opacity 0.2s ease';

                var xhr = new XMLHttpRequest();
                xhr.open('GET', '/Spec/Explore' + qs, true);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

                xhr.onload = function () {
                    if (xhr.status >= 200 && xhr.status < 300) {
                        /* Inject HTML */
                        resultsWrapper.innerHTML = xhr.responseText;

                        /* Cập nhật count */
                        var cards = resultsWrapper.querySelectorAll('.col');
                        var empty = resultsWrapper.querySelector('.empty-state');
                        if (resultCount) {
                            resultCount.textContent = empty ? '0' : cards.length;
                        }

                        /* Cập nhật URL */
                        history.replaceState(null, '', '/Spec/Explore' + qs);

                        /* Khởi tạo lại Waveform Player cho các card âm thanh mới được inject */
                        if (typeof window.initWaveformPlayers === 'function') {
                            window.initWaveformPlayers();
                        }

                        /* Re-apply ngôn ngữ */
                        var lang = localStorage.getItem('bpcvn-lang') || 'vi';
                        if (typeof window.applyLang === 'function') {
                            window.applyLang(lang);
                        }
                    }
                    resultsWrapper.style.opacity = '1';
                    resultsWrapper.style.pointerEvents = 'auto';
                };

                xhr.onerror = function () {
                    resultsWrapper.style.opacity = '1';
                    resultsWrapper.style.pointerEvents = 'auto';
                };

                xhr.send();
            }

            /* Debounce — chờ 300ms sau phím cuối rồi mới fetch */
            function debounceSearch() {
                clearTimeout(timer);
                timer = setTimeout(doSearch, 300);
            }

            /* ── Gắn sự kiện ── */

            /* Mỗi phím gõ → debounce → fetch */
            searchInput.addEventListener('input', debounceSearch);

            /* Đổi dropdown → fetch ngay */
            if (switchSelect) {
                switchSelect.addEventListener('change', doSearch);
            }

            /* Chặn form submit (nút Lọc) → dùng AJAX thay thế */
            if (exploreForm) {
                exploreForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    doSearch();
                });
            }

            /* Back/Forward trình duyệt */
            window.addEventListener('popstate', function () {
                var params = new URLSearchParams(window.location.search);
                searchInput.value = params.get('searchString') || '';
                if (switchSelect) switchSelect.value = params.get('switchType') || '';
                doSearch();
            });

        })();

        /* ── Upvote handler ── */
        function handleUpvote(btn) {
            var testId = btn.dataset.testId;
            btn.disabled = true;
            var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenEl ? tokenEl.value : '';
            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/SoundTest/Upvote', true);
            xhr.setRequestHeader('Content-Type', 'application/json');
            xhr.setRequestHeader('RequestVerificationToken', token);
            xhr.onload = function () {
                if (xhr.status >= 200 && xhr.status < 300) {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) {
                        btn.querySelector('.upvote-count').textContent = data.newCount;
                        btn.classList.add('upvoted');
                    } else { btn.disabled = false; }
                } else { btn.disabled = false; }
            };
            xhr.onerror = function () { btn.disabled = false; };
            xhr.send(JSON.stringify({ testId: testId }));
        }
    </script>
}