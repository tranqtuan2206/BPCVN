@model BPCVN.Models.ViewModels.SpecCreateViewModel
@{
    ViewData["Title"] = "Tạo Build mới";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="mb-4">
            <h2 class="fw-bold" style="color:#1a1a2e">
                <i class="bi bi-plus-circle me-2" style="color:#6c5ce7"></i>Tạo Build mới
            </h2>
            <p class="text-muted">Chia sẻ cấu hình bàn phím của bạn với cộng đồng</p>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger small rounded-3"></div>

                <!-- Tên build -->
                <div class="mb-3">
                    <label asp-for="BuildName" class="form-label fw-500"></label>
                    <input asp-for="BuildName" class="form-control rounded-3"
                           placeholder="VD: Neo65 Endgame Build..." />
                    <span asp-validation-for="BuildName" class="text-danger small"></span>
                </div>

                <!-- Kit + Switch -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="KitName" class="form-label fw-500"></label>
                        <input asp-for="KitName" class="form-control rounded-3"
                               placeholder="VD: Neo65, QK75, Zoom65 V2..." />
                        <span asp-validation-for="KitName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SwitchName" class="form-label fw-500"></label>
                        <input asp-for="SwitchName" class="form-control rounded-3"
                               placeholder="VD: Boba U4T, Cherry MX Black..." />
                        <span asp-validation-for="SwitchName" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Keycap -->
                <div class="mb-3">
                    <label asp-for="KeycapName" class="form-label fw-500"></label>
                    <input asp-for="KeycapName" class="form-control rounded-3"
                           placeholder="VD: GMK Nord, EPBT BoW... (để trống nếu không có)" />
                </div>

                <!-- Plate + Foam -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="PlateMaterial" class="form-label fw-500"></label>
                        <input asp-for="PlateMaterial" class="form-control rounded-3"
                               placeholder="VD: Aluminium, PC, FR4..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FoamSetup" class="form-label fw-500"></label>
                        <input asp-for="FoamSetup" class="form-control rounded-3"
                               placeholder="VD: Case foam + PE foam..." />
                    </div>
                </div>

                <!-- Mods -->
                <div class="mb-4">
                    <label asp-for="Mods" class="form-label fw-500"></label>
                    <textarea asp-for="Mods" class="form-control rounded-3" rows="3"
                              placeholder="VD: Tape mod, tempest mod, switch film..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn px-4 py-2 rounded-3"
                            style="background:#6c5ce7;color:#fff;font-weight:600">
                        <i class="bi bi-floppy me-2"></i>Lưu Build
                    </button>
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-light px-4 py-2 rounded-3">
                        Huỷ
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}