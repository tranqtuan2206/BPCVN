@model BPCVN.Models.ViewModels.SpecCreateViewModel
@{
    ViewData["Title"] = "Tạo Build mới";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <!-- Page header -->
        <div class="mb-4">
            <h2 class="section-title">
                <i class="bi bi-plus-circle me-2" style="opacity:0.5"></i>Tạo Build mới
            </h2>
            <p class="section-subtitle">Chia sẻ cấu hình bàn phím của bạn với cộng đồng</p>
        </div>

        <!-- Form card — Lovable style -->
        <div class="card-lovable card-body-lovable">
            <!-- Form — giữ nguyên asp-action, asp-for, asp-validation-* -->
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly"
                     class="validation-summary-lovable"></div>

                <!-- Tên build -->
                <div class="mb-3">
                    <label asp-for="BuildName" class="form-label-lovable"></label>
                    <input asp-for="BuildName" class="form-control"
                           placeholder="VD: Neo65 Endgame Build..." />
                    <span asp-validation-for="BuildName" class="text-danger small"></span>
                </div>

                <!-- Kit + Switch -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="KitName" class="form-label-lovable"></label>
                        <input asp-for="KitName" class="form-control"
                               placeholder="VD: Neo65, QK75, Zoom65 V2..." />
                        <span asp-validation-for="KitName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SwitchName" class="form-label-lovable"></label>
                        <input asp-for="SwitchName" class="form-control"
                               placeholder="VD: Boba U4T, Cherry MX Black..." />
                        <span asp-validation-for="SwitchName" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Keycap -->
                <div class="mb-3">
                    <label asp-for="KeycapName" class="form-label-lovable"></label>
                    <input asp-for="KeycapName" class="form-control"
                           placeholder="VD: GMK Nord, EPBT BoW... (để trống nếu không có)" />
                </div>

                <!-- Plate + Foam -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="PlateMaterial" class="form-label-lovable"></label>
                        <input asp-for="PlateMaterial" class="form-control"
                               placeholder="VD: Aluminium, PC, FR4..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FoamSetup" class="form-label-lovable"></label>
                        <input asp-for="FoamSetup" class="form-control"
                               placeholder="VD: Case foam + PE foam..." />
                    </div>
                </div>

                <!-- Mods -->
                <div class="mb-4">
                    <label asp-for="Mods" class="form-label-lovable"></label>
                    <textarea asp-for="Mods" class="form-control" rows="3"
                              placeholder="VD: Tape mod, tempest mod, switch film..."></textarea>
                </div>

                <!-- Buttons -->
                <div class="d-flex gap-2">
                    <!-- Primary Dark -->
                    <button type="submit" class="btn-dark-lovable px-4 py-2">
                        <i class="bi bi-floppy"></i>Lưu Build
                    </button>
                    <!-- Ghost cancel -->
                    <a asp-controller="Home" asp-action="Index"
                       class="btn-ghost px-4 py-2">
                        Huỷ
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}