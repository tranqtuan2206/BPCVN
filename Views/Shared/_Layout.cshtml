<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BPCVN</title>

    <!-- Google Font: Inter (Vietnamese subset) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap&subset=vietnamese"
        rel="stylesheet" />

    <!-- Bootstrap CSS + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Lovable Design System -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- ── Navbar ─────────────────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg sticky-top navbar-lovable">
        <div class="container">

            <!-- Logo / Brand — viền hồng #fb7aec, giữ nguyên asp-* -->
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="brand-logo">
                    <i class="bi bi-keyboard"></i>
                </span>
                <span>BPCVN</span>
            </a>

            <!-- Mobile toggle — radius 6px theo Design System -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <!-- ── Menu trái — phân quyền theo Role ── -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2 gap-1">

                    <!-- Trang chủ — luôn hiển thị -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i><span data-i18n="nav.home">Trang chủ</span>
                        </a>
                    </li>

                    <!-- ── Menu dành cho Admin ── -->
                    @if (User.IsInRole("Admin"))



                    {
                        <!-- Dropdown Quản lý — chứa Kits, Switches, Keycaps -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <i class="bi bi-gear me-1"></i>Quản lý
                            </a>
                            <ul class="dropdown-menu"
                                style="background:var(--color-cream);border-color:var(--border-light)">
                                <li>
                                    <a class="dropdown-item" asp-controller="Kit" asp-action="Index"
                                        style="color:var(--color-charcoal)">
                                        <i class="bi bi-cpu me-2"></i>Kits
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Switch" asp-action="Index"
                                        style="color:var(--color-charcoal)">
                                        <i class="bi bi-toggles me-2"></i>Switches
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Keycap" asp-action="Index"
                                        style="color:var(--color-charcoal)">
                                        <i class="bi bi-grid-3x3-gap me-2"></i>Keycaps
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                    <!-- ── Menu dành cho User thường / chưa đăng nhập ── -->
                    @if (!User.IsInRole("Admin"))



                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Kit" asp-action="Index">
                                <i class="bi bi-cpu me-1"></i>Kits
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Switch" asp-action="Index">
                                <i class="bi bi-toggles me-1"></i>Switches
                            </a>
                        </li>
                        <!-- Keycaps — mục mới cho User -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Keycap" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap me-1"></i>Keycaps
                            </a>
                        </li>
                    }

                    <!-- Gõ Phím — luôn hiển thị -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TypingTest" asp-action="Index">
                            <i class="bi bi-keyboard me-1"></i><span data-i18n="nav.typing">Gõ Phím</span>
                        </a>
                    </li>

                    <!-- Khám phá — luôn hiển thị -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Spec" asp-action="Explore">
                            <i class="bi bi-search me-1"></i><span data-i18n="nav.explore">Khám phá</span>
                        </a>
                    </li>

                </ul>

                <!-- ── Menu phải — Ngôn ngữ, Tài khoản, Tạo Build ── -->
                <div class="d-flex align-items-center gap-2">

                    <!-- Dropdown Ngôn ngữ — .nav-item.dropdown chuẩn Bootstrap 5, hỗ trợ hover CSS -->
                    <div class="nav-item dropdown lang-switcher" id="langSwitcher">
                        <button class="lang-toggle dropdown-toggle" type="button" data-bs-toggle="dropdown"
                            aria-expanded="false" title="Chuyển ngôn ngữ">
                            <span class="lang-flag" id="langFlag">VN</span>
                            <span class="lang-label" id="langLabel">VN</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end"
                            style="background:var(--color-cream);border-color:var(--border-light);min-width:180px">
                            <li>
                                <button class="dropdown-item lang-option" data-lang="en" onclick="setLang('en')"
                                    style="color:var(--color-charcoal)">
                                    <span class="lang-flag me-2">GB</span>English
                                    <i class="bi bi-check2 lang-check ms-auto" id="checkEn"></i>
                                </button>
                            </li>
                            <li>
                                <button class="dropdown-item lang-option" data-lang="vi" onclick="setLang('vi')"
                                    style="color:var(--color-charcoal)">
                                    <span class="lang-flag me-2">VN</span>Tiếng Việt
                                    <i class="bi bi-check2 lang-check ms-auto" id="checkVi"></i>
                                </button>
                            </li>
                        </ul>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)



                    {
                        <!-- Dropdown Tài khoản — .nav-item.dropdown chuẩn Bootstrap 5, hỗ trợ hover CSS -->
                        <div class="nav-item dropdown">
                            <button class="btn-ghost btn-sm-lovable dropdown-toggle" type="button" data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <i class="bi bi-person-circle"></i>
                                @User.Identity.Name
                                @if (User.IsInRole("Admin"))



                                {
                                    <span class="badge-warm"
                                        style="font-size:0.65rem;padding:2px 6px;margin-left:4px">Admin</span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end"
                                style="background:var(--color-cream);border-color:var(--border-light)">
                                <li>
                                    <a class="dropdown-item" asp-controller="User" asp-action="Profile"
                                        style="color:var(--color-charcoal)">
                                        <i class="bi bi-person me-2"></i>Trang cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword"
                                        style="color:var(--color-charcoal)">
                                        <i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu
                                    </a>
                                </li>
                                <li>
                                    <hr class="dropdown-divider" style="border-color:var(--border-light)">
                                </li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                                        <button type="submit" class="dropdown-item" style="color:#b91c1c">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>

                        <!-- Nút Tạo Build — ngoài cùng bên phải -->
                        <a class="btn-dark-lovable" asp-controller="Spec" asp-action="Create">
                            <i class="bi bi-plus-circle"></i><span data-i18n="nav.createBuild">Tạo Build</span>
                        </a>
                    }



                    else



                    {
                        <!-- Đăng nhập — Ghost button -->
                        <a class="btn-ghost" asp-controller="Auth" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i><span data-i18n="nav.login">Đăng nhập</span>
                        </a>
                        <!-- Đăng ký — Primary Dark button -->
                        <a class="btn-dark-lovable" asp-controller="Auth" asp-action="Register">
                            <i class="bi bi-person-plus"></i><span data-i18n="nav.register">Đăng ký</span>
                        </a>
                    }

                </div>

            </div>
        </div>
    </nav>

    <!-- AntiForgery token toàn cục — dùng cho AJAX Upvote -->
    @Html.AntiForgeryToken()

    <!-- Toast thông báo Success -->
    @if (TempData["Success"] != null)







    {
        <div class="toast-fixed">
            <div class="toast-lovable toast-success" id="successToast">
                <i class="bi bi-check-circle-fill toast-icon"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="toast-close" onclick="document.getElementById('successToast').remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    }

    <!-- Toast thông báo Error -->
    @if (TempData["Error"] != null)







    {
        <div class="toast-fixed">
            <div class="toast-lovable toast-error" id="errorToast">
                <i class="bi bi-exclamation-circle-fill toast-icon"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="toast-close" onclick="document.getElementById('errorToast').remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    }

    <!-- Main content -->
    <main class="container py-4 py-lg-5">
        @RenderBody()
    </main>


    <!-- ── Dark/Light Mode Toggle — góc dưới bên phải ────────────────────── -->
    <button id="themeToggle" class="theme-toggle" title="Chuyển chế độ sáng/tối" onclick="toggleTheme()">
        <i class="bi bi-moon-fill theme-icon-dark"></i>
        <i class="bi bi-sun-fill theme-icon-light"></i>
    </button>

    <!-- ── Footer ────────────────────────────────────────────────────────── -->
    <footer class="footer-lovable">
        <div class="container">
            <i class="bi bi-keyboard me-1"></i>
            <strong>BPCVN</strong> &mdash;
            <span data-i18n="footer.text">Cộng đồng Bàn Phím Cơ Việt Nam</span> &copy; @DateTime.Now.Year
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Tự động ẩn toast sau 4 giây -->
    <script>
        setTimeout(() => {
            document.getElementById('successToast')?.remove();
            document.getElementById('errorToast')?.remove();
        }, 4000);
    </script>

    <!-- Dark/Light Mode Script —
         - Đọc preference từ localStorage
         - Toggle class 'dark' trên <html>
         - Lưu lại preference khi click -->
    <script>
        (function () {
            // Khôi phục theme từ localStorage khi load trang
            const saved = localStorage.getItem('bpcvn-theme');
            if (saved === 'dark') {
                document.documentElement.classList.add('dark');
            }
        })();

        function toggleTheme() {
            const html = document.documentElement;
            html.classList.toggle('dark');

            // Lưu preference
            const isDark = html.classList.contains('dark');
            localStorage.setItem('bpcvn-theme', isDark ? 'dark' : 'light');
        }
    </script>

