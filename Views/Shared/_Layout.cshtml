<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BPCVN</title>

    <!-- Favicon -->
    <link rel="icon" href="~/icons/Logo-BPCVN-removebg.png" type="image/png" />

    <!-- Google Font: Inter (Vietnamese subset) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap&subset=vietnamese"
        rel="stylesheet" />

    <!-- Bootstrap CSS + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Lovable Design System -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- ── Navbar ─────────────────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg sticky-top navbar-lovable">
        <div class="container">

            <!-- Logo — ảnh custom + chữ BPCVN, nhấn chuột đổi ảnh mô phỏng switch cơ -->
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <img class="navbar-logo-switch" style="transform: translateY(1px);"
                    src="~/icons/Logo-BPCVN-removebg.png" alt="BPCVN Logo" />
                <span class="text-pixel"
                    style="font-size: 2rem; transform: translateY(-4px); letter-spacing: 0.7px;">BPCVN</span>
            </a>

            <!-- Mobile toggle — radius 6px theo Design System -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <!-- ── Menu trái — phân quyền theo Role ── -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2 gap-1">

                    <!-- Trang chủ — luôn hiển thị -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i><span data-i18n="nav.home">Trang chủ</span>
                        </a>
                    </li>

                    <!-- ── Menu dành cho Admin ── -->
                    @if (User.IsInRole("Admin"))















                    {
                            <!-- Dropdown Quản lý — chứa Kits, Switches, Keycaps -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    <i class="bi bi-gear me-1"></i><span data-i18n="nav.management">Quản lý</span>
                                </a>
                                <ul class="dropdown-menu"
                                    style="background:var(--color-cream);border-color:var(--border-light)">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Kit" asp-action="Index"
                                            style="color:var(--color-charcoal)">
                                            <img src="~/icons/kit-removebg.png" class="custom-nav-icon" alt="icon" /><span data-i18n="nav.kits">Kits</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Switch" asp-action="Index"
                                            style="color:var(--color-charcoal)">
                                            <img src="~/icons/switch-removebg.png" class="custom-nav-icon" alt="icon" /><span data-i18n="nav.switches">Switches</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Keycap" asp-action="Index"
                                            style="color:var(--color-charcoal)">
                                            <img src="~/icons/keycap-removebg.png" class="custom-nav-icon" alt="icon" /><span data-i18n="nav.keycaps">Keycaps</span>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                    }

                    <!-- ── Menu dành cho User thường / chưa đăng nhập ── -->
                    @if (!User.IsInRole("Admin"))



                    {
                            <!-- Gom nhóm Kits, Switches, Keycaps thành Dropdown Linh Kiện -->
                            <li class="nav-item dropdown hover-dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownLinhKien" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-layers me-1"></i> <span data-i18n="nav.parts">Đồ Chơi</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarDropdownLinhKien">
                                    <li><a class="dropdown-item" asp-controller="Kit" asp-action="Index"><img
                                                src="~/icons/kit-removebg.png" class="custom-nav-icon" alt="icon" /> <span data-i18n="nav.kits">Kits</span></a>
                                    </li>
                                    <li><a class="dropdown-item" asp-controller="Switch" asp-action="Index"><img
                                                src="~/icons/switch-removebg.png" class="custom-nav-icon" alt="icon" />
                                            <span data-i18n="nav.switches">Switches</span></a></li>
                                    <li><a class="dropdown-item" asp-controller="Keycap" asp-action="Index"><img
                                                src="~/icons/keycap-removebg.png" class="custom-nav-icon" alt="icon" />
                                            <span data-i18n="nav.keycaps">Keycaps</span></a></li>
                                </ul>
                            </li>
                    }

                    <!-- Gõ Phím — luôn hiển thị -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TypingTest" asp-action="Index">
                            <i class="bi bi-keyboard me-1"></i><span data-i18n="nav.typing">Gõ Phím</span>
                        </a>
                    </li>

                    <!-- Khám phá — luôn hiển thị -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Spec" asp-action="Explore">
                            <i class="bi bi-search me-1"></i><span data-i18n="nav.explore">Khám phá</span>
                        </a>
                    </li>

                </ul>

                <!-- ── Menu phải — Ngôn ngữ, Tài khoản, Tạo Build ── -->
                <div class="d-flex align-items-center gap-2">

                    <!-- Dropdown Ngôn ngữ — .nav-item.dropdown chuẩn Bootstrap 5, hỗ trợ hover CSS -->
                    <div class="nav-item dropdown lang-switcher" id="langSwitcher">
                        <button class="lang-toggle dropdown-toggle" type="button" data-bs-toggle="dropdown"
                            aria-expanded="false" title="Chuyển ngôn ngữ">
                            <span class="lang-flag" id="langFlag">VN</span>
                            <span class="lang-label" id="langLabel">VN</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end"
                            style="background:var(--color-cream);border-color:var(--border-light);min-width:180px">
                            <li>
                                <button class="dropdown-item lang-option" data-lang="en" onclick="setLang('en')"
                                    style="color:var(--color-charcoal)">
                                    <span class="lang-flag me-2">GB</span>English
                                    <i class="bi bi-check2 lang-check ms-auto" id="checkEn"></i>
                                </button>
                            </li>
                            <li>
                                <button class="dropdown-item lang-option" data-lang="vi" onclick="setLang('vi')"
                                    style="color:var(--color-charcoal)">
                                    <span class="lang-flag me-2">VN</span>Tiếng Việt
                                    <i class="bi bi-check2 lang-check ms-auto" id="checkVi"></i>
                                </button>
                            </li>
                        </ul>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)















                    {
                            <!-- Dropdown Tài khoản — .nav-item.dropdown chuẩn Bootstrap 5, hỗ trợ hover CSS -->
                            <div class="nav-item dropdown">
                                <button class="btn-ghost btn-sm-lovable dropdown-toggle" type="button" data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                @User.Identity.Name
                                @if (User.IsInRole("Admin"))















                                {
                                            <span class="badge-warm"
                                                style="font-size:0.65rem;padding:2px 6px;margin-left:4px">Admin</span>
                                }
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end"
                                    style="background:var(--color-cream);border-color:var(--border-light)">
                                    <li>
                                        <a class="dropdown-item" asp-controller="User" asp-action="Profile"
                                            style="color:var(--color-charcoal)">
                                            <i class="bi bi-person me-2"></i><span data-i18n="nav.myProfile">Trang cá nhân</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword"
                                            style="color:var(--color-charcoal)">
                                            <i class="bi bi-shield-lock me-2"></i><span data-i18n="nav.changePassword">Đổi mật khẩu</span>
                                        </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider" style="border-color:var(--border-light)">
                                    </li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                                            <button type="submit" class="dropdown-item" style="color:#b91c1c">
                                                <i class="bi bi-box-arrow-right me-2"></i><span data-i18n="nav.logout">Đăng xuất</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>

                            <!-- Nút Tạo Build — ngoài cùng bên phải -->
                            <a class="btn-dark-lovable" asp-controller="Spec" asp-action="Create">
                                <i class="bi bi-plus-circle"></i><span data-i18n="nav.createBuild">Tạo Build</span>
                            </a>
                    }

                    else
                    {
                            <!-- Đăng nhập — Ghost button -->
                            <a class="btn-ghost" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i><span data-i18n="nav.login">Đăng nhập</span>
                            </a>
                            <!-- Đăng ký — Primary Dark button -->
                            <a class="btn-dark-lovable" asp-controller="Auth" asp-action="Register">
                                <i class="bi bi-person-plus"></i><span data-i18n="nav.register">Đăng ký</span>
                            </a>
                    }

                </div>

            </div>
        </div>
    </nav>

    <!-- AntiForgery token toàn cục — dùng cho AJAX Upvote -->
    @Html.AntiForgeryToken()

    <!-- Toast thông báo Success -->
    @if (TempData["Success"] != null)
    {
            <div class="toast-fixed">
                <div class="toast-lovable toast-success" id="successToast">
                    <i class="bi bi-check-circle-fill toast-icon"></i>
                    <span data-i18n="@TempData["Success"]" data-i18n-param="@(TempData["SuccessParam"] ?? "")">@TempData["Success"]</span>
                    <button type="button" class="toast-close" onclick="document.getElementById('successToast').remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
    }

    <!-- Toast thông báo Error -->
    @if (TempData["Error"] != null)
    {
            <div class="toast-fixed">
                <div class="toast-lovable toast-error" id="errorToast">
                    <i class="bi bi-exclamation-circle-fill toast-icon"></i>
                    <span data-i18n="@TempData["Error"]">@TempData["Error"]</span>
                    <button type="button" class="toast-close" onclick="document.getElementById('errorToast').remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
    }

    <!-- Main content -->
    <main class="container py-4 py-lg-5">
        @RenderBody()
    </main>

<!-- ── Nút FAB mở Game — nằm phía trên nút Dark/Light Mode ───────────── -->
    <button id="gameFab" class="game-fab" title="Chơi Typing Defense!" onclick="openGameModal()">
        <i class="bi bi-controller"></i>
    </button>

    <!-- ── Game Modal Overlay — ẩn mặc định, hiện khi click FAB ─────────── -->
    <div id="gameOverlay" class="game-overlay" onclick="handleOverlayClick(event)">
        <div class="game-container">
            <!-- Nút X đóng modal — góc trên phải container -->
            <button class="game-close-btn" title="Đóng game" onclick="closeGameModal()">
                <i class="bi bi-x-lg"></i>
            </button>
            <!-- Iframe nhúng game Unity WebGL —
                 src được set khi mở và xóa khi đóng để tránh game chạy ngầm -->
            <iframe id="gameFrame"
                    src=""
                    frameborder="0"
                    allowfullscreen
                    class="game-iframe">
            </iframe>
        </div>
    </div>

    <!-- ── Dark/Light Mode Toggle — góc dưới bên phải ────────────────────── -->
    <button id="themeToggle" class="theme-toggle" title="Chuyển chế độ sáng/tối" onclick="toggleTheme()">
        <i class="bi bi-moon-fill theme-icon-dark"></i>
        <i class="bi bi-sun-fill theme-icon-light"></i>
    </button>

    <!-- ── Footer ────────────────────────────────────────────────────────── -->
    <footer class="footer-lovable">
        <div class="container">
            <i class="bi bi-keyboard me-1"></i>
            <strong>BPCVN</strong> &mdash;
            <span data-i18n="footer.text">Cộng đồng Bàn Phím Cơ Việt Nam</span> &copy; @DateTime.Now.Year
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Tự động ẩn toast sau 4 giây -->
    <script>
        setTimeout(() => {
            document.getElementById('successToast')?.remove();
            document.getElementById('errorToast')?.remove();
        }, 4000);
    </script>

    <!-- Dark/Light Mode Script —
         - Đọc preference từ localStorage
         - Toggle class 'dark' trên <html>
         - Lưu lại preference khi click -->
    <script>
        (function () {
            // Khôi phục theme từ localStorage khi load trang
            const saved = localStorage.getItem('bpcvn-theme');
            if (saved === 'dark') {
                document.documentElement.classList.add('dark');
            }
        })();

        function toggleTheme() {
            const html = document.documentElement;
            html.classList.toggle('dark');

            // Lưu preference
            const isDark = html.classList.contains('dark');
            localStorage.setItem('bpcvn-theme', isDark ? 'dark' : 'light');
        }
    </script>

    <!-- ── Language Switcher Script ────────────────────────────────────────── -->
    <script src="~/js/translations.js"></script>
    <script>
        /* Áp dụng ngôn ngữ: quét tất cả [data-i18n] và thay text */
        function applyLang(lang) {
            const dict = translations[lang];
            if (!dict) return;

            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (dict[key]) {
                    let text = dict[key];
                    const param = el.getAttribute('data-i18n-param');
                    if (param) text = text.replace('{0}', param);
                    el.textContent = text;
                }
            });

            document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
                const key = el.getAttribute('data-i18n-placeholder');
                if (dict[key]) el.placeholder = dict[key];
            });

            // Cập nhật flag + label trên nút chính
            document.getElementById('langFlag').textContent = lang === 'vi' ? 'VN' : 'EN';
            document.getElementById('langLabel').textContent = lang === 'vi' ? 'VN' : 'EN';

            // Cập nhật dấu check trong dropdown
            document.getElementById('checkVi').style.display = lang === 'vi' ? 'inline' : 'none';
            document.getElementById('checkEn').style.display = lang === 'en' ? 'inline' : 'none';

            // Cập nhật lang attribute trên html
            document.documentElement.setAttribute('lang', lang);

            // Dịch validation messages (server-rendered)
            if (typeof window.validationMap === 'undefined') {
                window.validationMap = {
                    vi: {
                        'Username là bắt buộc': 'Username là bắt buộc',
                        'Email là bắt buộc': 'Email là bắt buộc',
                        'Email không hợp lệ': 'Email không hợp lệ',
                        'Mật khẩu là bắt buộc': 'Mật khẩu là bắt buộc',
                        'Vui lòng nhập mật khẩu': 'Vui lòng nhập mật khẩu',
                        'Vui lòng xác nhận mật khẩu': 'Vui lòng xác nhận mật khẩu',
                        'Mật khẩu không khớp': 'Mật khẩu không khớp',
                        'Username từ 3-50 ký tự': 'Username từ 3-50 ký tự',
                        'Mật khẩu ít nhất 6 ký tự': 'Mật khẩu ít nhất 6 ký tự',
                        'Email này đã được sử dụng.': 'Email này đã được sử dụng.',
                        'Username này đã được sử dụng.': 'Username này đã được sử dụng.',
                        'Email hoặc mật khẩu không đúng.': 'Email hoặc mật khẩu không đúng.',
                        'Mật khẩu hiện tại không đúng.': 'Mật khẩu hiện tại không đúng.',
                        'Vui lòng nhập mật khẩu hiện tại': 'Vui lòng nhập mật khẩu hiện tại',
                        'Vui lòng nhập mật khẩu mới': 'Vui lòng nhập mật khẩu mới',
                        'Mật khẩu mới ít nhất 6 ký tự': 'Mật khẩu mới ít nhất 6 ký tự',
                        'Vui lòng xác nhận mật khẩu mới': 'Vui lòng xác nhận mật khẩu mới',
                        'Mật khẩu xác nhận không khớp': 'Mật khẩu xác nhận không khớp',
                        'Tài khoản chưa được kích hoạt, vui lòng kiểm tra email.': 'Tài khoản chưa được kích hoạt, vui lòng kiểm tra email.',
                    },
                    en: {
                        'Username là bắt buộc': 'Username is required',
                        'Email là bắt buộc': 'Email is required',
                        'Email không hợp lệ': 'Invalid email address',
                        'Mật khẩu là bắt buộc': 'Password is required',
                        'Vui lòng nhập mật khẩu': 'Password is required',
                        'Vui lòng xác nhận mật khẩu': 'Please confirm your password',
                        'Mật khẩu không khớp': 'Passwords do not match',
                        'Username từ 3-50 ký tự': 'Username must be 3-50 characters',
                        'Mật khẩu ít nhất 6 ký tự': 'Password must be at least 6 characters',
                        'Email này đã được sử dụng.': 'This email is already in use.',
                        'Username này đã được sử dụng.': 'This username is already taken.',
                        'Email hoặc mật khẩu không đúng.': 'Invalid email or password.',
                        'Mật khẩu hiện tại không đúng.': 'Current password is incorrect.',
                        'Vui lòng nhập mật khẩu hiện tại': 'Please enter your current password',
                        'Vui lòng nhập mật khẩu mới': 'Please enter a new password',
                        'Mật khẩu mới ít nhất 6 ký tự': 'New password must be at least 6 characters',
                        'Vui lòng xác nhận mật khẩu mới': 'Please confirm your new password',
                        'Mật khẩu xác nhận không khớp': 'Passwords do not match',
                        'Tài khoản chưa được kích hoạt, vui lòng kiểm tra email.': 'Account not activated, please check your email.',
                    }
                };
            }
            const vMap = window.validationMap[lang] || window.validationMap.vi;
            document.querySelectorAll('.text-danger').forEach(el => {
                const text = el.textContent.trim();
                if (vMap[text]) el.textContent = vMap[text];
            });
        }

        /* Đặt ngôn ngữ + lưu localStorage, đóng dropdown bằng Bootstrap API */
        function setLang(lang) {
            localStorage.setItem('bpcvn-lang', lang);
            applyLang(lang);
            // Đóng dropdown ngôn ngữ qua Bootstrap 5 API
            const toggler = document.querySelector('#langSwitcher .dropdown-toggle');
            if (toggler) {
                const bsDropdown = bootstrap.Dropdown.getOrCreateInstance(toggler);
                bsDropdown.hide();
            }
        }

        /* Khôi phục ngôn ngữ khi load trang */
        (function () {
            var saved = localStorage.getItem('bpcvn-lang') || 'vi';
            applyLang(saved);

            function translateValidationMessages() {
                var lang = localStorage.getItem('bpcvn-lang') || 'vi';
                var vMap = (typeof window.validationMap !== 'undefined' && window.validationMap[lang]) || {};
                document.querySelectorAll('.text-danger, .validation-summary-lovable li, .validation-summary-lovable').forEach(function (el) {
                    var text = el.textContent.trim();
                    if (vMap[text]) el.textContent = vMap[text];
                });
            }

            // Override jQuery Validate để mỗi lần show error đều dịch
            function patchjQueryValidate() {
                if (typeof $ === 'undefined' || !$.validator) return false;

                var origShowErrors = $.validator.prototype.showErrors;
                $.validator.prototype.showErrors = function () {
                    origShowErrors.call(this);
                    translateValidationMessages();
                };

                var origHighlight = $.validator.prototype.highlight;
                $.validator.prototype.highlight = function (element) {
                    origHighlight.call(this, element);
                    translateValidationMessages();
                };

                return true;
            }

            if (!patchjQueryValidate()) {
                var jqCheck = setInterval(function () {
                    if (patchjQueryValidate()) clearInterval(jqCheck);
                }, 100);
                setTimeout(function () { clearInterval(jqCheck); }, 5000);
            }

            // Fallback cho server-side validation
            document.querySelectorAll('form').forEach(function (form) {
                form.addEventListener('submit', function () {
                    setTimeout(translateValidationMessages, 200);
                    setTimeout(translateValidationMessages, 500);
                });
            });
        })();
    </script>

    <!-- WaveSurfer.js — Waveform Audio Player -->
    <script type="module" src="~/js/waveform-setup.js"></script>

    <!-- ── Game Modal Script ──────────────────────────────────────────────── -->
    <script>
        var GAME_URL = 'https://tranqtuan2206.github.io/Typing-Defense/';

        /* Mở modal: hiện overlay + nạp game vào iframe */
        function openGameModal() {
            var overlay = document.getElementById('gameOverlay');
            var frame   = document.getElementById('gameFrame');
            frame.src = GAME_URL;          // Bắt đầu load game khi mở
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden'; // Chặn cuộn trang khi đang chơi
        }

        /* Đóng modal: ẩn overlay + xóa src để dừng game, giải phóng tài nguyên */
        function closeGameModal() {
            var overlay = document.getElementById('gameOverlay');
            var frame   = document.getElementById('gameFrame');
            overlay.classList.remove('active');
            frame.src = '';                // Dừng game, không để chạy ngầm
            document.body.style.overflow = ''; // Mở lại cuộn trang
        }

        /* Click ra ngoài vùng container (vào vùng mờ) → đóng modal */
        function handleOverlayClick(e) {
            if (e.target === document.getElementById('gameOverlay')) {
                closeGameModal();
            }
        }

        /* Phím Escape cũng đóng modal */
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeGameModal();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
