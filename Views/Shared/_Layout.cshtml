<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BPCVN</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root { --accent: #6c5ce7; --accent-light: #ede9fe; }

        body { background: #f5f4fb; font-family: 'Segoe UI', sans-serif; }

        /* Navbar */
        .navbar { background: #fff !important; border-bottom: 1px solid #e9e6fd; }
        .navbar-brand { font-weight: 800; font-size: 1.2rem; color: #1a1a2e !important; letter-spacing: -.3px; }
        .navbar-brand .accent { color: var(--accent); }
        .nav-link { font-weight: 500; color: #444 !important; border-radius: 8px; padding: 6px 14px !important; transition: all .15s; }
        .nav-link:hover, .nav-link.active { background: var(--accent-light); color: var(--accent) !important; }

        .btn-upload { background: var(--accent); color: #fff !important; border-radius: 10px; font-weight: 600; padding: 7px 20px; border: none; transition: background .15s; }
        .btn-upload:hover { background: #5849c2; }

        /* Toast thông báo */
        .toast-fixed { position: fixed; top: 72px; right: 20px; z-index: 9999; min-width: 300px; }

        /* Footer */
        footer { font-size: .82rem; color: #999; }

        /* Card hover */
        .card { transition: transform .18s, box-shadow .18s; }
        .card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(108,92,231,.12) !important; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg sticky-top shadow-sm">
    <div class="container">

        <a class="navbar-brand d-flex align-items-center gap-2"
           asp-controller="Home" asp-action="Index">
            <i class="bi bi-keyboard fs-5" style="color:var(--accent)"></i>
            <span>BPC<span class="accent">VN</span></span>
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">

            <!-- Menu trái -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2 gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Trang chủ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Kit" asp-action="Index">
                        <i class="bi bi-cpu me-1"></i>Kits
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Switch" asp-action="Index">
                        <i class="bi bi-toggles me-1"></i>Switches
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Spec" asp-action="Index">
                        <i class="bi bi-search me-1"></i>Khám phá
                    </a>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="User" asp-action="Profile">
                            <i class="bi bi-person-circle me-1"></i>Của tôi
                        </a>
                    </li>
                }
            </ul>

            <!-- Menu phải — thay đổi theo trạng thái đăng nhập -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="d-flex align-items-center gap-2">
                    <!-- Nút tạo build -->
                    <a class="btn btn-upload" asp-controller="Spec" asp-action="Create">
                        <i class="bi bi-plus-circle me-1"></i>Tạo Build
                    </a>

                    <!-- Nút logout hiển thị tên user -->
                    <form asp-controller="Auth" asp-action="Logout"
                          method="post" class="mb-0">
                        <button type="submit"
                                class="btn btn-light rounded-3 border fw-500 px-3"
                                style="font-size:.9rem">
                            <i class="bi bi-person-circle me-1" style="color:var(--accent)"></i>
                            @User.Identity.Name
                            <i class="bi bi-box-arrow-right ms-2 text-muted"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="d-flex gap-2">
                    <a class="btn btn-light border rounded-3 fw-500 px-3"
                       asp-controller="Auth" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                    </a>
                    <a class="btn btn-upload"
                       asp-controller="Auth" asp-action="Register">
                        <i class="bi bi-person-plus me-1"></i>Đăng ký
                    </a>
                </div>
            }

        </div>
    </div>
</nav>

<!-- AntiForgery token toàn cục — dùng cho AJAX Upvote -->
@Html.AntiForgeryToken()

<!-- Toast thông báo Success -->
@if (TempData["Success"] != null)
{
    <div class="toast-fixed">
        <div class="alert alert-success shadow d-flex align-items-center gap-2 rounded-3 mb-0"
             id="successToast">
            <i class="bi bi-check-circle-fill flex-shrink-0"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto"
                    onclick="document.getElementById('successToast').remove()"></button>
        </div>
    </div>
}

<!-- Toast thông báo Error -->
@if (TempData["Error"] != null)
{
    <div class="toast-fixed">
        <div class="alert alert-danger shadow d-flex align-items-center gap-2 rounded-3 mb-0"
             id="errorToast">
            <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
            <span>@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto"
                    onclick="document.getElementById('errorToast').remove()"></button>
        </div>
    </div>
}

<main class="container py-4 py-lg-5">
    @RenderBody()
</main>

<footer class="border-top text-center py-4 mt-4 bg-white">
    <div class="container">
        <i class="bi bi-keyboard me-1" style="color:var(--accent)"></i>
        <strong style="color:var(--accent)">BPCVN</strong> &mdash;
        Cộng đồng Bàn Phím Cơ Việt Nam &copy; @DateTime.Now.Year
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- Tự động ẩn toast sau 4 giây -->
<script>
    setTimeout(() => {
        document.getElementById('successToast')?.remove();
        document.getElementById('errorToast')?.remove();
    }, 4000);
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>