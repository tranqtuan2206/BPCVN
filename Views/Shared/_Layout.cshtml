<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BPCVN</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root { --accent: #6c5ce7; --accent-light: #ede9fe; }

        body { background: #f5f4fb; font-family: 'Segoe UI', sans-serif; }

        /* Navbar */
        .navbar { background: #fff !important; border-bottom: 1px solid #e9e6fd; }
        .navbar-brand { font-weight: 800; font-size: 1.2rem; color: #1a1a2e !important; letter-spacing: -.3px; }
        .navbar-brand .accent { color: var(--accent); }
        .nav-link { font-weight: 500; color: #444 !important; border-radius: 8px; padding: 6px 14px !important; transition: all .15s; }
        .nav-link:hover, .nav-link.active { background: var(--accent-light); color: var(--accent) !important; }
        .btn-upload { background: var(--accent); color: #fff !important; border-radius: 10px; font-weight: 600; padding: 7px 20px; border: none; transition: background .15s; }
        .btn-upload:hover { background: #5849c2; }

        /* Footer */
        footer { font-size: .82rem; color: #999; }

        /* Card hover */
        .card { transition: transform .18s, box-shadow .18s; }
        .card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(108,92,231,.12) !important; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg sticky-top shadow-sm">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            <i class="bi bi-keyboard fs-5" style="color:var(--accent)"></i>
            <span>BPC<span class="accent">VN</span></span>
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2 gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Trang chủ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Kit" asp-action="Index">
                        <i class="bi bi-cpu me-1"></i>Kits
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Switch" asp-action="Index">
                        <i class="bi bi-toggles me-1"></i>Switches
                    </a>
                </li>
            </ul>

            <a class="btn btn-upload ms-2" href="#">
                <i class="bi bi-cloud-upload me-1"></i>Upload Build
            </a>
        </div>
    </div>
</nav>

<main class="container py-4 py-lg-5">
    @RenderBody()
</main>

<footer class="border-top text-center py-4 mt-4 bg-white">
    <div class="container">
        <i class="bi bi-keyboard me-1" style="color:var(--accent)"></i>
        <strong style="color:var(--accent)">BPCVN</strong> &mdash;
        Cộng đồng Bàn Phím Cơ Việt Nam &copy; @DateTime.Now.Year
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
