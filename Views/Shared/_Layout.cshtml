<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BPCVN</title>

    <!-- Google Font: Inter (Vietnamese subset) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap&subset=vietnamese"
          rel="stylesheet" />

    <!-- Bootstrap CSS + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Lovable Design System -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- ── Navbar ─────────────────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg sticky-top navbar-lovable">
        <div class="container">

            <!-- Logo / Brand — viền hồng #fb7aec, giữ nguyên asp-* -->
            <a class="navbar-brand d-flex align-items-center gap-2"
               asp-controller="Home" asp-action="Index">
                <span class="brand-logo">
                    <i class="bi bi-keyboard"></i>
                </span>
                <span>BPCVN</span>
            </a>

            <!-- Mobile toggle — radius 6px theo Design System -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <!-- Menu trái — giữ nguyên toàn bộ asp-controller/asp-action -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2 gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Kit" asp-action="Index">
                            <i class="bi bi-cpu me-1"></i>Kits
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Switch" asp-action="Index">
                            <i class="bi bi-toggles me-1"></i>Switches
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Spec" asp-action="Explore">
                            <i class="bi bi-search me-1"></i>Khám phá
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)

                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="User" asp-action="Profile">
                                <i class="bi bi-person-circle me-1"></i>Của tôi
                            </a>
                        </li>
                    }
                </ul>

                <!-- Menu phải — thay đổi theo trạng thái đăng nhập -->
                @if (User.Identity?.IsAuthenticated == true)

                {
                    <div class="d-flex align-items-center gap-2">
                        <!-- Nút tạo build — Primary Dark button -->
                        <a class="btn-dark-lovable" asp-controller="Spec" asp-action="Create">
                            <i class="bi bi-plus-circle"></i>Tạo Build
                        </a>

                        <!-- Nút logout hiển thị tên user — Ghost button -->
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                            <button type="submit" class="btn-ghost btn-sm-lovable">
                                <i class="bi bi-person-circle"></i>
                                @User.Identity.Name
                                <i class="bi bi-box-arrow-right ms-1" style="opacity:0.5"></i>
                            </button>
                        </form>
                    </div>
                }

                else

                {
                    <div class="d-flex gap-2">
                        <!-- Đăng nhập — Ghost button -->
                        <a class="btn-ghost" asp-controller="Auth" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i>Đăng nhập
                        </a>
                        <!-- Đăng ký — Primary Dark button -->
                        <a class="btn-dark-lovable" asp-controller="Auth" asp-action="Register">
                            <i class="bi bi-person-plus"></i>Đăng ký
                        </a>
                    </div>
                }

            </div>
        </div>
    </nav>

    <!-- AntiForgery token toàn cục — dùng cho AJAX Upvote -->
    @Html.AntiForgeryToken()

    <!-- Toast thông báo Success -->
    @if (TempData["Success"] != null)

    {
        <div class="toast-fixed">
            <div class="toast-lovable toast-success" id="successToast">
                <i class="bi bi-check-circle-fill toast-icon"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="toast-close"
                        onclick="document.getElementById('successToast').remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    }

    <!-- Toast thông báo Error -->
    @if (TempData["Error"] != null)

    {
        <div class="toast-fixed">
            <div class="toast-lovable toast-error" id="errorToast">
                <i class="bi bi-exclamation-circle-fill toast-icon"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="toast-close"
                        onclick="document.getElementById('errorToast').remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    }

    <!-- Main content -->
    <main class="container py-4 py-lg-5">
        @RenderBody()
    </main>

    <!-- ── Dark/Light Mode Toggle — góc dưới bên phải ────────────────────── -->
    <button id="themeToggle" class="theme-toggle" title="Chuyển chế độ sáng/tối"
            onclick="toggleTheme()">
        <!-- Icon mặt trời (light) / mặt trăng (dark) -->
        <i class="bi bi-moon-fill theme-icon-dark"></i>
        <i class="bi bi-sun-fill theme-icon-light"></i>
    </button>

    <!-- ── Footer ────────────────────────────────────────────────────────── -->
    <footer class="footer-lovable">
        <div class="container">
            <i class="bi bi-keyboard me-1"></i>
            <strong>BPCVN</strong> &mdash;
            Cộng đồng Bàn Phím Cơ Việt Nam &copy; @DateTime.Now.Year
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Tự động ẩn toast sau 4 giây -->
    <script>
        setTimeout(() => {
            document.getElementById('successToast')?.remove();
            document.getElementById('errorToast')?.remove();
        }, 4000);
    </script>

    <!-- Dark/Light Mode Script —
         - Đọc preference từ localStorage
         - Toggle class 'dark' trên <html>
         - Lưu lại preference khi click -->
    <script>
        (function () {
            // Khôi phục theme từ localStorage khi load trang
            const saved = localStorage.getItem('bpcvn-theme');
            if (saved === 'dark') {
                document.documentElement.classList.add('dark');
            }
        })();

        function toggleTheme() {
            const html = document.documentElement;
            html.classList.toggle('dark');

            // Lưu preference
            const isDark = html.classList.contains('dark');
            localStorage.setItem('bpcvn-theme', isDark ? 'dark' : 'light');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>