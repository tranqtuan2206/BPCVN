@model IEnumerable<BPCVN.Models.Entities.Kit>
@{
    ViewData["Title"] = "Kit Catalog";
}

<!-- Page header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h2 class="fw-bold mb-1" style="color:#1a1a2e">
            <i class="bi bi-cpu me-2" style="color:#6c5ce7"></i>Kit Catalog
        </h2>
        <p class="text-muted mb-0">@Model.Count() kits trong cơ sở dữ liệu</p>
    </div>
    <span class="badge rounded-pill px-3 py-2 fs-6"
          style="background:#ede9fe;color:#5849c2">
        @Model.Count() Kits
    </span>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
        <p class="fs-5">Chưa có kit nào. Hãy chạy seeder!</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @foreach (var kit in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4" style="overflow:hidden">

                    <!-- Ảnh hoặc placeholder -->
                    @if (!string.IsNullOrEmpty(kit.ImageUrl))
                    {
                        <img src="@kit.ImageUrl" class="card-img-top"
                             style="height:190px;object-fit:cover" alt="@kit.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center"
                             style="height:190px;background:linear-gradient(135deg,#ede9fe,#f5f4fb)">
                            <i class="bi bi-keyboard" style="font-size:4rem;color:#c4b5fd;opacity:.6"></i>
                        </div>
                    }

                    <div class="card-body pb-2">
                        <!-- Layout badge -->
                        @if (!string.IsNullOrEmpty(kit.Layout))
                        {
                            <span class="badge mb-2"
                                  style="background:#ede9fe;color:#5849c2;font-size:.75rem;font-weight:600">
                                @kit.Layout
                            </span>
                        }

                        <h5 class="card-title fw-bold mb-1" style="color:#1a1a2e">@kit.Name</h5>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-building me-1"></i>@(kit.Brand ?? "Unknown Brand")
                        </p>

                        <!-- Quick specs -->
                        <ul class="list-unstyled small text-secondary mb-0">
                            @if (!string.IsNullOrEmpty(kit.MountType))
                            {
                                <li class="mb-1">
                                    <i class="bi bi-layers me-2" style="color:#6c5ce7"></i>@kit.MountType
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(kit.PcbType))
                            {
                                <li>
                                    <i class="bi bi-motherboard me-2" style="color:#6c5ce7"></i>@kit.PcbType
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="card-footer bg-white border-0 px-3 pb-3 pt-2">
                        <a href="#" class="btn btn-sm w-100 fw-600"
                           style="background:#ede9fe;color:#5849c2;border-radius:8px;font-weight:600">
                            <i class="bi bi-arrow-right-circle me-1"></i>Xem chi tiết
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
}
