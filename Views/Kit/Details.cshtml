@model BPCVN.Models.Entities.Kit
@{
    ViewData["Title"] = Model.Name + " — Kit Details";
}

<!-- Header: Tên Kit + nút hành động -->
<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-cpu me-2" style="opacity:0.5"></i>@Model.Name
        </h2>
        <p class="text-caption mb-0">
            <i class="bi bi-building me-1"></i>@(Model.Brand ?? "Unknown Brand")
            @if (!string.IsNullOrEmpty(Model.Layout))
            {
                <span data-i18n="kit.details.separator">&nbsp;·&nbsp;</span>
                <i class="bi bi-grid-3x3 me-1"></i>@Model.Layout
            }
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Kit" asp-action="Edit" asp-route-id="@Model.KitId"
               class="btn-dark-lovable">
                <i class="bi bi-pencil-square"></i><span data-i18n="common.edit">Chỉnh sửa</span>
            </a>
            <a asp-controller="Kit" asp-action="Delete" asp-route-id="@Model.KitId"
               class="btn-ghost" style="color:#b91c1c">
                <i class="bi bi-trash"></i><span data-i18n="common.delete">Xóa</span>
            </a>
        }
        <a asp-controller="Kit" asp-action="Index" class="btn-ghost">
            <i class="bi bi-arrow-left"></i><span data-i18n="common.backToList">Danh sách</span>
        </a>
    </div>
</div>

<!-- Ảnh Kit (nếu có) -->
@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div class="card-lovable mb-4 overflow-hidden">
        <img src="@Model.ImageUrl" class="w-100 img-detail-contain"
             alt="@Model.Name" />
    </div>
}

<!-- Thông số chi tiết Kit -->
<div class="card-lovable card-body-lovable mb-4">
    <h5 style="font-weight:600;color:var(--color-charcoal);margin-bottom:16px">
        <i class="bi bi-sliders me-2" style="opacity:0.5"></i><span data-i18n="kit.details.specs">Thông số Kit</span>
    </h5>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-tag me-1"></i><span data-i18n="kit.details.name">Tên Kit</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">@Model.Name</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-building me-1"></i><span data-i18n="kit.details.brand">Hãng (Brand)</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.Brand ?? "—")
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-grid-3x3 me-1"></i><span data-i18n="kit.details.layout">Layout</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.Layout ?? "—")
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-layers me-1"></i><span data-i18n="kit.details.mountType">Mount Type</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.MountType ?? "—")
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-motherboard me-1"></i><span data-i18n="kit.details.pcbType">PCB Type</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.PcbType ?? "—")
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Nút hành động dưới cùng -->
<div class="d-flex gap-2">
    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Kit" asp-action="Edit" asp-route-id="@Model.KitId"
           class="btn-dark-lovable">
            <i class="bi bi-pencil-square"></i><span data-i18n="common.edit">Chỉnh sửa</span>
        </a>
        <a asp-controller="Kit" asp-action="Delete" asp-route-id="@Model.KitId"
           class="btn-ghost" style="color:#b91c1c">
            <i class="bi bi-trash"></i><span data-i18n="common.delete">Xóa</span>
        </a>
    }
    <a asp-controller="Kit" asp-action="Index" class="btn-ghost">
        <i class="bi bi-arrow-left"></i><span data-i18n="common.backToList">Quay lại danh sách</span>
    </a>
</div>
