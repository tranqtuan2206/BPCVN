@model BPCVN.Models.Entities.Kit
@{
    ViewData["Title"] = Model.Name + " — Kit Details";
}

<!-- Header: Tên Kit + nút hành động -->
<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-cpu me-2" style="opacity:0.5"></i>@Model.Name
        </h2>
        <p class="text-caption mb-0">
            <i class="bi bi-building me-1"></i>@(Model.Brand ?? "Unknown Brand")
            @if (!string.IsNullOrEmpty(Model.Layout))
            {
                <span>&nbsp;·&nbsp;</span>
                <i class="bi bi-grid-3x3 me-1"></i>@Model.Layout
            }
        </p>
    </div>
    <div class="d-flex gap-2">
        <!-- Nút Chỉnh sửa Kit -->
        <a asp-controller="Kit" asp-action="Edit" asp-route-id="@Model.KitId"
           class="btn-dark-lovable">
            <i class="bi bi-pencil-square"></i>Chỉnh sửa
        </a>
        <!-- Nút Quay lại danh sách -->
        <a asp-controller="Kit" asp-action="Index" class="btn-ghost">
            <i class="bi bi-arrow-left"></i>Danh sách
        </a>
    </div>
</div>

<!-- Ảnh Kit (nếu có) -->
@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div class="card-lovable mb-4 overflow-hidden">
        <img src="@Model.ImageUrl" class="w-100"
             style="max-height:400px;object-fit:cover" alt="@Model.Name" />
    </div>
}

<!-- Thông số chi tiết Kit -->
<div class="card-lovable card-body-lovable mb-4">
    <h5 style="font-weight:600;color:var(--color-charcoal);margin-bottom:16px">
        <i class="bi bi-sliders me-2" style="opacity:0.5"></i>Thông số Kit
    </h5>
    <div class="row g-3">
        <!-- Tên Kit -->
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-tag me-1"></i>Tên Kit</div>
                <div style="font-weight:600;color:var(--color-charcoal)">@Model.Name</div>
            </div>
        </div>

        <!-- Hãng sản xuất -->
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-building me-1"></i>Hãng (Brand)</div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.Brand ?? "—")
                </div>
            </div>
        </div>

        <!-- Layout -->
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-grid-3x3 me-1"></i>Layout</div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.Layout ?? "—")
                </div>
            </div>
        </div>

        <!-- Mount Type (Gasket, Top, Tray...) -->
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-layers me-1"></i>Mount Type</div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.MountType ?? "—")
                </div>
            </div>
        </div>

        <!-- PCB Type (Hotswap / Soldered) -->
        <div class="col-md-4">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-motherboard me-1"></i>PCB Type</div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.PcbType ?? "—")
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Nút hành động dưới cùng -->
<div class="d-flex gap-2">
    <a asp-controller="Kit" asp-action="Edit" asp-route-id="@Model.KitId"
       class="btn-dark-lovable">
        <i class="bi bi-pencil-square"></i>Chỉnh sửa
    </a>
    <a asp-controller="Kit" asp-action="Index" class="btn-ghost">
        <i class="bi bi-arrow-left"></i>Quay lại danh sách
    </a>
</div>
