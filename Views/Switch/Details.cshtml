@model BPCVN.Models.Entities.Switch
@{
    ViewData["Title"] = Model.Name + " — Switch Details";

    // Xác định icon dựa trên loại Switch
    string iconClass;
    if (Model.Type == "Linear") { iconClass = "bi-arrow-down"; }
    else if (Model.Type == "Tactile") { iconClass = "bi-arrow-down-up"; }
    else if (Model.Type == "Clicky") { iconClass = "bi-volume-up"; }
    else { iconClass = "bi-question-circle"; }
}

<!-- Header: Tên Switch + nút hành động -->
<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h2 class="section-title mb-1">
            <i class="bi bi-toggles me-2" style="opacity:0.5"></i>@Model.Name
        </h2>
        <p class="text-caption mb-0">
            <i class="bi bi-building me-1"></i>@(Model.Brand ?? "Unknown Brand")
            @if (!string.IsNullOrEmpty(Model.Type))
            {
                <span>&nbsp;·&nbsp;</span>
                <i class="bi @iconClass me-1"></i>@Model.Type
            }
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <!-- Nút Chỉnh sửa Switch — chỉ Admin -->
            <a asp-controller="Switch" asp-action="Edit" asp-route-id="@Model.SwitchId"
               class="btn-dark-lovable">
                <i class="bi bi-pencil-square"></i><span data-i18n="common.edit">Chỉnh sửa</span>
            </a>
            <!-- Nút Xóa Switch — chỉ Admin -->
            <a asp-controller="Switch" asp-action="Delete" asp-route-id="@Model.SwitchId"
               class="btn-ghost" style="color:#b91c1c">
                <i class="bi bi-trash"></i><span data-i18n="common.delete">Xóa</span>
            </a>
        }
        <!-- Nút Quay lại danh sách -->
        <a asp-controller="Switch" asp-action="Index" class="btn-ghost">
            <i class="bi bi-arrow-left"></i><span data-i18n="common.backToList">Danh sách</span>
        </a>
    </div>
</div>

<!-- Ảnh minh hoạ Switch (hoặc icon nếu không có ảnh) -->
@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div class="card-lovable mb-4 overflow-hidden">
        <img src="@Model.ImageUrl" class="w-100 img-detail-contain"
             alt="@Model.Name" />
    </div>
}
else
{
    <div class="card-lovable mb-4 overflow-hidden">
        <div class="img-placeholder" style="height:200px">
            <i class="bi @iconClass" style="font-size:5rem"></i>
        </div>
    </div>
}

<!-- Thông số chi tiết Switch -->
<div class="card-lovable card-body-lovable mb-4">
    <h5 style="font-weight:600;color:var(--color-charcoal);margin-bottom:16px">
        <i class="bi bi-sliders me-2" style="opacity:0.5"></i><span data-i18n="switch.details.specs">Thông số Switch</span>
    </h5>
    <div class="row g-3">
        <!-- Tên Switch -->
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-tag me-1"></i><span data-i18n="switch.details.name">Tên Switch</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">@Model.Name</div>
            </div>
        </div>

        <!-- Hãng sản xuất -->
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-building me-1"></i><span data-i18n="common.brand">Hãng (Brand)</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.Brand ?? "—")
                </div>
            </div>
        </div>

        <!-- Loại Switch -->
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi @iconClass me-1"></i><span data-i18n="common.type">Loại (Type)</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.Type ?? "—")
                </div>
            </div>
        </div>

        <!-- Lực nhấn -->
        <div class="col-md-6">
            <div class="info-block">
                <div class="text-caption mb-1"><i class="bi bi-speedometer2 me-1"></i><span data-i18n="switch.details.actuationForce">Lực nhấn</span></div>
                <div style="font-weight:600;color:var(--color-charcoal)">
                    @(Model.ActuationForce ?? "—")
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Nút hành động dưới cùng -->
<div class="d-flex gap-2">
    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Switch" asp-action="Edit" asp-route-id="@Model.SwitchId"
           class="btn-dark-lovable">
            <i class="bi bi-pencil-square"></i><span data-i18n="common.edit">Chỉnh sửa</span>
        </a>
        <a asp-controller="Switch" asp-action="Delete" asp-route-id="@Model.SwitchId"
           class="btn-ghost" style="color:#b91c1c">
            <i class="bi bi-trash"></i><span data-i18n="common.delete">Xóa</span>
        </a>
    }
    <a asp-controller="Switch" asp-action="Index" class="btn-ghost">
        <i class="bi bi-arrow-left"></i><span data-i18n="common.backToList">Quay lại danh sách</span>
    </a>
</div>
