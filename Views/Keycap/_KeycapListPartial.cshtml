@model IEnumerable<BPCVN.Models.Entities.Keycap>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-inbox empty-icon"></i>
        <p class="text-body-lg" data-i18n="keycap.list.empty">Không tìm thấy keycap nào phù hợp.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @foreach (var keycap in Model)
        {
            <div class="col">
                <div class="card-lovable h-100 d-flex flex-column">
                    @if (!string.IsNullOrEmpty(keycap.ImageUrl))
                    {
                        <img src="@keycap.ImageUrl" class="img-lovable img-card-cover"
                            alt="@keycap.Name" />
                    }
                    else
                    {
                        <div class="img-placeholder" style="height:190px">
                            <i class="bi bi-grid-3x3-gap" style="font-size:4rem"></i>
                        </div>
                    }
                    <div class="p-3 flex-grow-1">
                        <!-- Badge Profile (Cherry, SA, OEM...) -->
                        @if (!string.IsNullOrEmpty(keycap.Profile))
                        {
                            <span class="badge-warm badge-kit mb-2" style="font-size:.75rem">@keycap.Profile</span>
                        }
                        <!-- Badge Material (PBT, ABS...) -->
                        @if (!string.IsNullOrEmpty(keycap.Material))
                        {
                            <span class="badge-warm badge-type mb-2" style="font-size:.75rem">@keycap.Material</span>
                        }
                        <h5 style="font-weight:600;color:var(--color-charcoal);margin-bottom:4px">@keycap.Name</h5>
                        <p class="text-caption mb-3">
                            <i class="bi bi-building me-1"></i>@(keycap.Brand ?? "Unknown Brand")
                        </p>
                    </div>
                    <div class="px-3 pb-3 pt-1 d-flex gap-2">
                        <!-- Nút Xem chi tiết -->
                        <a asp-controller="Keycap" asp-action="Details" asp-route-id="@keycap.KeycapId"
                            class="btn-ghost btn-sm-lovable flex-grow-1 text-center">
                            <i class="bi bi-arrow-right-circle"></i>Xem chi tiết
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <!-- Nút Chỉnh sửa — chỉ Admin mới thấy -->
                            <a asp-controller="Keycap" asp-action="Edit" asp-route-id="@keycap.KeycapId"
                                class="btn-ghost btn-sm-lovable" title="Chỉnh sửa">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <!-- Nút Xóa — chỉ Admin mới thấy -->
                            <a asp-controller="Keycap" asp-action="Delete" asp-route-id="@keycap.KeycapId"
                                class="btn-ghost btn-sm-lovable" title="Xóa"
                                style="color:#b91c1c">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
